{
  "buildCommand": "composer install --no-dev --no-interaction --prefer-dist && npm run build",
  "outputDirectory": ".",
  "publicPath": "public",
  "env": {
    "APP_ENV": "production"
  },
  "functions": {
    "api/**.php": {
      "runtime": "vercel-php@0.6.1"
    }
  },
  "routes": [
    {
      "src": "^/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "^/storage/(.*)",
      "dest": "/storage/$1"
    },
    {
      "src": "^(?!/api)(.*)",
      "dest": "/api/index.php"
    }
  ]
}